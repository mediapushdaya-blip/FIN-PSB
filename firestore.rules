rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the user is an admin
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'media.pushdaya@gmail.com'
      );
    }

    function isValidTransaction(data) {
      return data.tanggal is string && 
             data.deskripsi is string && data.deskripsi.size() <= 1000 &&
             data.kategori is string &&
             data.nominal is number &&
             data.status is string &&
             data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create: if isSignedIn() && isValidTransaction(request.resource.data);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (resource.data.userId == request.auth.uid && 
         isValidTransaction(request.resource.data) && 
         request.resource.data.userId == resource.data.userId)
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() ||
        request.auth.token.email == 'media.pushdaya@gmail.com'
      );
    }

    // Public path for connection test
    match /config/status {
      allow read: if true;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
